# Root environment template for quick local setup
# Copy and adapt values to backend/.env and frontend/.env.local as needed.

# Backend
OLLAMA_HOST=http://localhost:11434
OLLAMA_SQL_MODEL=qwen2.5-coder:3b
OLLAMA_NARRATE_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_KEEP_ALIVE=30m
STORAGE_DIR=./storage
MAX_UPLOAD_MB=100
MAX_FILES_PER_SESSION=15
SQL_ROW_LIMIT=10000
SQL_TIMEOUT_SECONDS=30
CSV_INFER_SAMPLE_ROWS=200000
CLEANSING_CAST_RATIO=0.98
OUTLIER_CLIP_ENABLED=true
OUTLIER_CLIP_LOWER_Q=0.01
OUTLIER_CLIP_UPPER_Q=0.99
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3003

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
